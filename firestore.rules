rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} { allow read, create: if true; allow update, delete: if request.auth != null; }
    match /allowed_technicians/{re} { allow read: if true; allow write: if request.auth != null; }
    match /allowed_admins/{cpf} { allow read: if true; allow write: if request.auth != null; }
    match /requests/{id} { allow read, write: if true; }
    match /scripts/{id} { allow read: if true; allow write: if request.auth != null; }
    match /escala_servico/{id} { allow read: if true; allow write: if request.auth != null; }
    match /announcements/{id} { allow read, write: if true; }
    match /announcement_acknowledgments/{id} { allow read, write: if true; }
  }
}